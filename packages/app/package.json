{
  "name": "@slimfact/app",
  "version": "0.1.0",
  "private": true,
  "description": "SlimFact App",
  "author": "",
  "files": [
    "dist/"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fastify-ssr-plugin": {
      "import": "./dist/ssr/server/fastify-ssr-plugin.mjs"
    },
    "./hooks": {
      "import": "./dist/ssr/server/virtual_vitrify-hooks.mjs"
    }
  },
  "scripts": {
    "dev": "vitrify dev",
    "dev:ssr": "vitrify dev -m ssr",
    "build": "run-s build:ssr",
    "build:csr": "vitrify build",
    "build:ssr": "vitrify build -m ssr",
    "build:ssg": "vitrify build -m ssg",
    "minify:csr": "vitrify minify ./dist/csr",
    "minify:ssr:server": "vitrify minify ./dist/ssr/server",
    "minify:ssr:client": "vitrify minify ./dist/ssr/client",
    "minify:ssg": "vitrify minify ./dist/static",
    "minify:fastify": "vitrify minify ./dist/server",
    "generate:types": "vue-tsc -p tsconfig.types.json",
    "test": "vitrify test",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write ."
  },
  "dependencies": {
    "@fastify/middie": "9.3.2",
    "@fastify/static": "9.1.3",
    "@slimfact/tools": "workspace:*",
    "cronstrue": "3.14.0",
    "uqr": "0.1.3"
  },
  "devDependencies": {
    "@iconify-json/fa6-brands": "1.2.6",
    "@iconify-json/fa6-solid": "1.2.4",
    "@iconify-json/flagpack": "1.2.7",
    "@iconify-json/mdi": "1.2.3",
    "@modular-api/fastify-checkout": "0.5.17",
    "@modular-api/quasar-components": "0.3.38",
    "@myriaddreamin/typst-ts-renderer": "0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "@myriaddreamin/typst.vue3": "0.7.0-rc2",
    "@pinia/colada": "1.3.1",
    "@quasar/extras": "1.18.0",
    "@quasar/quasar-ui-qcalendar": "4.1.2",
    "@simsustech/quasar-components": "0.12.2",
    "@slimfact/api": "link:../api",
    "@slimfact/shared": "link:../shared",
    "@trpc/client": "11.17.0",
    "@trpc/server": "11.17.0",
    "@vitejs/plugin-basic-ssl": "2.3.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/reactivity": "3.5.34",
    "@vue/runtime-core": "3.5.34",
    "@vue/runtime-dom": "3.5.34",
    "@vue/server-renderer": "3.5.34",
    "@vue/shared": "3.5.34",
    "@vueuse/core": "14.3.0",
    "abort-controller": "3.0.0",
    "beasties": "0.4.2",
    "date-holidays": "3.30.2",
    "fastify": "5.8.5",
    "icon-gen": "5.0.0",
    "kysely": "0.29.2",
    "lionel-oauth-client": "npm:@stefanvh/lionel-oauth-client@^0.7.0",
    "node-fetch": "3.3.2",
    "npm-run-all": "4.1.5",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "pinia": "3.0.4",
    "quasar": "2.19.3",
    "typescript": "6.0.3",
    "unocss": "66.7.0",
    "unocss-preset-quasar": "0.2.13",
    "vite": "8.0.14",
    "vite-plugin-pwa": "1.3.0",
    "vitrify": "0.26.6",
    "vue": "3.5.34",
    "vue-router": "5.0.7",
    "vue-tsc": "3.3.2",
    "workbox-window": "7.4.1",
    "ws": "8.21.0"
  }
}
