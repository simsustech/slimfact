{
  "name": "@slimfact/tools",
  "version": "0.1.0",
  "author": "Stefan van Herwijnen",
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./epc-qr": {
      "types": "./dist/types/epc-qr/index.d.ts",
      "import": "./dist/epc-qr/index.js"
    },
    "./peppol": {
      "types": "./dist/types/peppol/index.d.ts",
      "import": "./dist/peppol/index.js"
    },
    "./digiboox": {
      "types": "./dist/types/digiboox/index.d.ts",
      "import": "./dist/digiboox/index.js"
    },
    "./typst": {
      "types": "./dist/types/typst/index.d.ts",
      "import": "./dist/typst/index.js"
    },
    "./ubl": {
      "types": "./dist/types/ubl/index.d.ts",
      "import": "./dist/ubl/index.js"
    },
    "./templates/invoice/*": {
      "import": "./templates/invoice/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write ."
  },
  "dependencies": {
    "@modular-api/fastify-checkout": "^0.5.12",
    "@myriaddreamin/typst-ts-renderer": "0.7.0-rc2",
    "@rgrove/parse-xml": "^4.2.0",
    "export-to-csv": "^1.4.0",
    "fast-xml-parser": "^5.7.2",
    "handlebars": "^4.7.9",
    "ibantools": "^4.5.4"
  },
  "devDependencies": {
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "@types/iban": "^0.0.35",
    "@types/node": "^25.6.0",
    "csv-parse": "^6.2.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "10.9.0",
    "kysely": "0.28.16",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vue-eslint-parser": "^10.4.0"
  }
}
