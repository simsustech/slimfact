{
  "name": "@slimfact/api",
  "version": "0.1.0",
  "private": true,
  "description": "SlimFact API",
  "author": "simsustech",
  "files": [
    "dist/",
    "vitrify.config.ts"
  ],
  "type": "module",
  "exports": {
    "./zod": {
      "types": "./src/zod/index.ts",
      "import": "./src/zod/index.ts"
    },
    "./trpc": {
      "types": "./src/trpc/index.ts"
    }
  },
  "scripts": {
    "serve": "node ./dist/server/server.mjs",
    "dev": "run-s docker-compose start:dev-server ",
    "build": "run-s build:api build:migrations seed:fake:generate minify:fastify",
    "build:migrations": "tsc -p tsconfig.migrations.json",
    "build:api": "vitrify build -m fastify",
    "minify:csr": "vitrify minify ./dist/csr",
    "minify:ssr:server": "vitrify minify ./dist/ssr/server",
    "minify:ssr:client": "vitrify minify ./dist/ssr/client",
    "minify:ssg": "vitrify minify ./dist/static",
    "minify:fastify": "vitrify minify ./dist/server",
    "test": "vitrify test",
    "test:e2e": "playwright test",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "migrate:latest": "node ./dist/migrate.js",
    "seed:fake:generate": "node ./dist/seeds/fake/writeData.js",
    "seed:fake": "node ./dist/seeds/fake.js",
    "seed:test": "node ./dist/seeds/test.js",
    "seed:data": "node ./dist/seeds/data.js",
    "start": "run-s migrate:latest serve",
    "start:dev-server": "NODE_TLS_REJECT_UNAUTHORIZED=0 vitrify dev -m fastify --port 3001",
    "docker-compose": "node ./docker-compose.dev.mjs"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/middie": "9.3.2",
    "@fastify/one-line-logger": "2.1.0",
    "@fastify/static": "9.1.3",
    "@modular-api/api": "0.6.23",
    "@modular-api/fastify-checkout": "0.5.12",
    "@modular-api/fastify-oidc": "0.9.20",
    "@mollie/api-client": "4.5.0",
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0-rc2",
    "@slimfact/app": "workspace:*",
    "@slimfact/tools": "workspace:*",
    "@trpc/server": "11.16.0",
    "@vitrify/tools": "0.5.1",
    "axios": "1.15.2",
    "bcryptjs": "3.0.3",
    "compress-tag": "3.0.0",
    "docker-compose": "1.4.2",
    "fastify": "5.8.5",
    "handlebars": "4.7.9",
    "json-2-csv": "5.5.10",
    "kysely": "0.28.16",
    "npm-run-all": "4.1.5",
    "otplib": "13.4.0",
    "pg": "8.20.0",
    "pg-boss": "12.18.1",
    "sharp": "0.34.5",
    "short-uuid": "^6.0.3",
    "svgo": "4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@iconify-json/fa6-brands": "1.2.6",
    "@iconify-json/fa6-solid": "1.2.4",
    "@iconify-json/flagpack": "1.2.7",
    "@iconify-json/mdi": "1.2.3",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "@playwright/test": "1.59.1",
    "@types/bcryptjs": "3.0.0",
    "@types/oidc-provider": "9.5.0",
    "@types/pg": "8.20.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "6.0.6",
    "beasties": "0.4.2",
    "date-fns": "4.1.0",
    "kysely-codegen": "0.20.0",
    "nodeunit": "0.11.3",
    "oidc-provider": "9.8.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "quasar": "2.19.3",
    "typescript": "6.0.3",
    "unocss": "66.6.8",
    "unocss-preset-quasar": "0.2.13",
    "vite": "8.0.10",
    "vitrify": "0.26.3",
    "vue": "3.5.33",
    "vue-router": "5.0.6"
  },
  "dependenciesMeta": {
    "@modular-api/fastify-oidc": {
      "injected": true
    }
  },
  "productName": "SlimFact API"
}
