{
  "name": "@slimfact/api",
  "version": "0.1.0",
  "private": true,
  "description": "SlimFact API",
  "author": "simsustech",
  "files": [
    "dist/",
    "vitrify.config.ts"
  ],
  "type": "module",
  "exports": {
    "./zod": {
      "types": "./src/zod/index.ts",
      "import": "./src/zod/index.ts"
    },
    "./trpc": {
      "types": "./src/trpc/index.ts"
    }
  },
  "scripts": {
    "serve": "node ./dist/server/server.mjs",
    "dev": "run-s docker-compose start:dev-server ",
    "build": "run-s build:api build:migrations seed:fake:generate minify:fastify",
    "build:debug": "run-s build:api:debug build:migrations seed:fake:generate",
    "build:api:debug": "vitrify build -m fastify --debug",
    "build:migrations": "tsc -p tsconfig.migrations.json",
    "build:api": "vitrify build -m fastify",
    "minify:csr": "vitrify minify ./dist/csr",
    "minify:ssr:server": "vitrify minify ./dist/ssr/server",
    "minify:ssr:client": "vitrify minify ./dist/ssr/client",
    "minify:ssg": "vitrify minify ./dist/static",
    "minify:fastify": "vitrify minify ./dist/server",
    "test": "vitrify test",
    "test:e2e": "playwright test",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "migrate:latest": "node ./dist/kysely/migrate.js",
    "seed:fake:generate": "node ./dist/kysely/seeds/fake/writeData.js",
    "seed:fake": "node ./dist/kysely/seeds/fake.js",
    "seed:test": "node ./dist/kysely/seeds/test.js",
    "seed:data": "node ./dist/kysely/seeds/data.js",
    "start": "run-s migrate:latest serve",
    "start:dev-server": "NODE_TLS_REJECT_UNAUTHORIZED=0 vitrify dev -m fastify --port 3001 --host",
    "docker-compose": "node ./docker-compose.dev.mjs"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/middie": "9.3.2",
    "@fastify/one-line-logger": "2.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "9.1.3",
    "@modular-api/api": "0.6.32",
    "@modular-api/fastify-checkout": "0.7.0",
    "@modular-api/fastify-oidc": "0.9.25",
    "@mollie/api-client": "4.5.0",
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0",
    "@slimfact/app": "workspace:*",
    "@slimfact/tools": "workspace:*",
    "@trpc/server": "11.18.0",
    "@vitrify/tools": "0.5.3",
    "axios": "1.18.1",
    "bcryptjs": "3.0.3",
    "compress-tag": "3.0.0",
    "docker-compose": "1.4.2",
    "fastify": "5.9.0",
    "handlebars": "4.7.9",
    "json-2-csv": "5.5.11",
    "kysely": "0.29.2",
    "npm-run-all": "4.1.5",
    "otplib": "13.4.1",
    "pg": "8.22.0",
    "pg-boss": "12.23.0",
    "sharp": "0.35.2",
    "short-uuid": "6.0.3",
    "stripe": "^22.3.0",
    "svgo": "4.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "10.5.0",
    "@iconify-json/fa6-brands": "1.2.6",
    "@iconify-json/fa6-solid": "1.2.4",
    "@iconify-json/flagpack": "1.2.8",
    "@iconify-json/mdi": "1.2.3",
    "@myriaddreamin/typst.ts": "0.7.0",
    "@playwright/test": "1.61.1",
    "@types/bcryptjs": "3.0.0",
    "@types/k6": "2.0.0",
    "@types/oidc-provider": "9.5.0",
    "@types/pg": "8.20.0",
    "@vitejs/plugin-basic-ssl": "2.3.0",
    "@vitejs/plugin-vue": "6.0.7",
    "beasties": "0.4.2",
    "date-fns": "4.4.0",
    "devcert": "1.2.3",
    "k6": "0.0.0",
    "kysely-codegen": "0.20.0",
    "nodeunit": "0.11.3",
    "oidc-provider": "9.8.6",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "quasar": "2.20.1",
    "typescript": "6.0.3",
    "unocss": "66.7.4",
    "unocss-preset-quasar": "0.3.4",
    "vite": "8.1.0",
    "vitrify": "0.26.11",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "dependenciesMeta": {
    "@modular-api/fastify-oidc": {
      "injected": true
    }
  },
  "productName": "SlimFact API"
}
